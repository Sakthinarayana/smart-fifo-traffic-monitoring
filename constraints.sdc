############################################################
# SMART FIFO SDC CONSTRAINT FILE
# Technology : 90nm
# Frequency  : 100 MHz
# Optimization : Timing + Area + Power
############################################################

############################################################
# CLOCK DEFINITION
############################################################

create_clock -name clk \
             -period 10 \
             [get_ports clk]

############################################################
# CLOCK UNCERTAINTY
############################################################

set_clock_uncertainty 0.2 [get_clocks clk]

############################################################
# CLOCK TRANSITION
############################################################

set_clock_transition 0.1 [get_clocks clk]

############################################################
# INPUT DELAY
############################################################

set_input_delay 1.0 \
    -clock clk \
    [remove_from_collection [all_inputs] [get_ports clk]]

############################################################
# OUTPUT DELAY
############################################################

set_output_delay 1.0 \
    -clock clk \
    [all_outputs]

############################################################
# DRIVING CELL
############################################################

set_driving_cell \
   -lib_cell BUF_X1 \
   [remove_from_collection [all_inputs] [get_ports clk]]

############################################################
# OUTPUT LOAD
############################################################

set_load 0.05 [all_outputs]

############################################################
# FALSE PATH FOR RESET
############################################################

set_false_path \
   -from [get_ports rst]

############################################################
# MAX FANOUT
############################################################

set_max_fanout 8 [current_design]

############################################################
# MAX TRANSITION
############################################################

set_max_transition 0.3 [current_design]

############################################################
# MAX CAPACITANCE
############################################################

set_max_capacitance 0.15 [current_design]

############################################################
# AREA OPTIMIZATION
############################################################

set_max_area 0

############################################################
# POWER OPTIMIZATION
############################################################

set_dynamic_optimization true

############################################################
# LEAKAGE POWER OPTIMIZATION
############################################################

set_leakage_optimization true

############################################################
# IDEAL NETWORK FOR RESET
############################################################

set_ideal_network [get_ports rst]

############################################################
# OPERATING CONDITIONS
############################################################

set_operating_conditions slow

############################################################
# WIRE LOAD MODEL
############################################################

set_wire_load_mode enclosed
